# ============================================================
# Stellenistberechnung – Umgebungsvariablen
# ============================================================
# Kopieren nach .env und Werte anpassen!
# ============================================================

# --- Datenbank ---
# Lokal (Entwicklung):
DATABASE_URL=postgres://stellenist:stellenist_local_2026@localhost:5433/stellenistberechnung
# Production (Docker):
# DATABASE_URL=postgresql://stellenist:SICHERES_PASSWORT@db:5432/stellenistberechnung

# --- Production Docker Compose (.env neben docker-compose.prod.yml) ---
# DB_PASSWORD wird in docker-compose.prod.yml fuer PostgreSQL + DATABASE_URL verwendet
# DB_PASSWORD=SICHERES_PASSWORT_HIER

# --- Session ---
# Mindestens 32 Zeichen! Generieren: openssl rand -base64 48
SESSION_SECRET=change-me-mindestens-32-zeichen-lang

# --- n8n Sync API ---
# Schluessel fuer den POST /api/deputate/sync Endpoint
API_SYNC_KEY=change-me-in-production
