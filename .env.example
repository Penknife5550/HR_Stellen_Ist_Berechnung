# ============================================================
# Stellenistberechnung – Umgebungsvariablen
# ============================================================
# Fuer lokale Entwicklung: Kopieren nach .env und Werte anpassen
# Fuer Production: .env neben docker-compose.prod.yml ablegen
# ============================================================

# --- Datenbank ---
# Lokal (Entwicklung): Port 5434 (vermeidet Kollision mit HR-Portal)
DATABASE_URL=postgres://stellenist:stellenist_local_2026@localhost:5434/stellenistberechnung

# --- Production Docker Compose ---
# DB_PASSWORD wird in docker-compose.prod.yml verwendet
# Generieren: openssl rand -hex 20
DB_PASSWORD=SICHERES_PASSWORT_HIER

# --- Session ---
# Mindestens 32 Zeichen! Generieren: openssl rand -base64 48
SESSION_SECRET=change-me-mindestens-32-zeichen-lang

# --- n8n Sync API ---
# Schluessel fuer den POST /api/deputate/sync Endpoint
# Muss im n8n-Workflow identisch konfiguriert sein
API_SYNC_KEY=change-me-in-production
