# ============================================================
# Production Environment – deputat.fes-credo.de
# ============================================================
# Diese Datei als .env neben docker-compose.prod.yml ablegen
# NIEMALS committen — enthält Secrets!
# ============================================================

# Datenbank-Passwort (generieren: openssl rand -hex 20)
DB_PASSWORD=HIER_SICHERES_PASSWORT

# Session-Secret (generieren: openssl rand -base64 48)
SESSION_SECRET=HIER_SESSION_SECRET_MINDESTENS_32_ZEICHEN

# n8n Sync API-Key (Bootstrap — sobald ueber /admin/n8n-webhooks der erste Key
# angelegt wurde, ist dieser Fallback dauerhaft deaktiviert)
API_SYNC_KEY=HIER_API_SYNC_KEY

# Schluessel fuer /api/notifications/dispatch (Cron/N8N pollt diesen Endpoint
# fuer Retry-Versand ausgehender Webhooks). Generieren: openssl rand -hex 32
NOTIFICATION_DISPATCH_KEY=HIER_DISPATCH_KEY
